{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach: Web App 1",
            "type": "node",
            "request": "attach",
            "address": "localhost",
            "port": 19226,
            "restart": true,
            "timeout": 120000,
            "trace": true,
            "sourceMaps": true,
            "smartStep": true,
            "skipFiles": [
                "<node_internals>/**"
            ],
            "localRoot": "${workspaceFolder}/apps/web-app-1"
        },
        {
            "name": "Attach: Server App 1",
            "type": "node",
            "request": "attach",
            "address": "localhost",
            "port": 19228,
            "restart": true,
            "timeout": 120000,
            "trace": true,
            "sourceMaps": true,
            "smartStep": true,
            "skipFiles": [
                "<node_internals>/**"
            ],
            "localRoot": "${workspaceFolder}/apps/server-app-1"
        },
        {
            "name": "Launch Browser: Web App 1",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:18080/web-app-1/",
            "webRoot": "${workspaceFolder}/apps/web-app-1/src"
        }
    ],
    "compounds": [
        {
            "name": "Debug: Web + Server",
            "configurations": [
                "Attach: Web App 1",
                "Attach: Server App 1"
            ]
        }
    ]
}